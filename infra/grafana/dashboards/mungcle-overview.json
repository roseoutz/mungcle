        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(grpc_server_calls_seconds_count{job=~\"$service\",statusCode!=\"OK\"}[1m])) by (job) / sum(rate(grpc_server_calls_seconds_count{job=~\"$service\"}[1m])) by (job)",
