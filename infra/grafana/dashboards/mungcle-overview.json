        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=~\"$service\"}[1m])) by (job, le))",
          "legendFormat": "p50 {{job}}",
          "refId": "A"
        }
      ],
      "title": "HTTP 레이턴시 P50 — 서비스별",
